# Example environment variables (do NOT commit real values)
# Copy to .env.local and fill values for local development

# Primary key used by your local `lib/gemini.ts` (replace if your code expects different name)
GEMINI_API_KEY=

# Some SDKs expect this variable name — set it as well if needed
GOOGLE_GENERATIVE_AI_API_KEY=

# Any other public or client keys (prefixed with NEXT_PUBLIC_) can be listed here too
NEXT_PUBLIC_SOME_KEY=
